# macOS
.DS_Store
**/.DS_Store

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# The precomputed cache IS committed so every deploy serves it from local disk
# instead of rebuilding from the NBA API on each restart (Hugging Face wipes
# storage on every rebuild, so an empty cache there = a full re-scrape per push).
# Refresh it deliberately by re-running seed_cache.py and committing.
# parquet/pkl are still ignored everywhere EXCEPT cache/ (keeps training scratch out).
*.parquet
*.pkl
!cache/*.parquet
!cache/*.pkl

# Local scratch / disabled pages (revert checkpoints — git history is the backup)
refresh_splits.py
app_archive_v1.py
Trades_backup.py
Trades_disabled.py
Track_Record_disabled.py

# Home-page layout backups (revert checkpoints — git history is the real backup)
app_home_*.py

# Original logo source files (processed final is static/hoopsvalue_logo.png)
static/ChatGPT*.png
static/hf_*.png

# Source data PDFs (facts extracted into data/*.csv; don't commit the docs)
*.pdf

# Design handoff (reference only — pull assets into static/ as needed)
design_handoff_hoopsvalue_refresh/

# Claude Code local dev config
.claude/
